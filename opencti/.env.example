# OpenCTI core
OPENCTI_BASE_URL=http://localhost:8080
OPENCTI_ADMIN_EMAIL=admin@opencti.local
OPENCTI_ADMIN_PASSWORD=CHANGE_ME_OPENCTI_ADMIN_PASSWORD
OPENCTI_ADMIN_TOKEN=CHANGE_ME_OPENCTI_ADMIN_TOKEN
OPENCTI_HEALTHCHECK_ACCESS_KEY=CHANGE_ME_OPENCTI_HEALTHCHECK_ACCESS_KEY
OPENCTI_ENCRYPTION_KEY=CHANGE_ME_OPENCTI_ENCRYPTION_KEY

# PostgreSQL
POSTGRES_DB=opencti
POSTGRES_USER=opencti
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# RabbitMQ
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBITMQ_PASSWORD

# MinIO
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# MITRE connector
CONNECTOR_MITRE_ID=00000000-0000-0000-0000-000000000001
CONNECTOR_MITRE_NAME=MITRE ATTACK
CONNECTOR_MITRE_SCOPE=identity,attack-pattern,course-of-action,intrusion-set,malware,tool,report
CONNECTOR_MITRE_AUTO=true
CONNECTOR_MITRE_INTERVAL=86400

# CISA KEV connector
CONNECTOR_CISA_KEV_ID=00000000-0000-0000-0000-000000000002
CONNECTOR_CISA_KEV_NAME=CISA KEV
CONNECTOR_CISA_KEV_SCOPE=vulnerability
CONNECTOR_CISA_KEV_AUTO=true
CISA_INTERVAL=3600
CISA_CATALOG_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# URLhaus connector
CONNECTOR_URLHAUS_ID=00000000-0000-0000-0000-000000000003
CONNECTOR_URLHAUS_NAME=URLhaus
CONNECTOR_URLHAUS_SCOPE=url,domain,ipv4-addr
CONNECTOR_URLHAUS_AUTO=true
CONNECTOR_URLHAUS_INTERVAL=3600
URLHAUS_CSV_URL=https://urlhaus.abuse.ch/downloads/csv_online/

# AlienVault OTX connector
CONNECTOR_ALIENVAULT_ID=00000000-0000-0000-0000-000000000004
CONNECTOR_ALIENVAULT_NAME=AlienVault OTX
CONNECTOR_ALIENVAULT_SCOPE=IPv4-Addr,Domain-Name,Hostname,File-md5,File-sha1,File-sha256,Url,Mutex,Email-Addr
CONNECTOR_ALIENVAULT_DURATION_PERIOD=P7D
ALIENVAULT_BASE_URL=https://otx.alienvault.com
ALIENVAULT_API_KEY=CHANGE_ME_ALIENVAULT_API_KEY
ALIENVAULT_CREATE_OBSERVABLES=true
ALIENVAULT_CREATE_INDICATORS=true
ALIENVAULT_PULSE_START_TIMESTAMP=2026-01-01T00:00:00
ALIENVAULT_REPORT_TYPE=threat-report
ALIENVAULT_REPORT_STATUS=new
ALIENVAULT_ENABLE_RELATIONSHIPS=true
ALIENVAULT_FILTER_INDICATORS=true
